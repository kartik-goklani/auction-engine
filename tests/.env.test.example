# ------------------------------------------------------------------
# Auction Engine — Test Environment
# Copy to .env.test and fill in your values.
# NEVER commit .env.test — it is gitignored.
# ------------------------------------------------------------------

# Supabase project (required by seed.py for direct DB access)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Backend base URL (must be running before running pytest)
BASE_URL=http://localhost:3001/api/v1

# Test user credentials (created by seed.py)
BUYER1_EMAIL=buyer1@aitt.test
BUYER1_PASSWORD=Seed1234!
BUYER2_EMAIL=buyer2@aitt.test
BUYER2_PASSWORD=Seed1234!
VENDOR1_EMAIL=vendor1@aitt.test
VENDOR1_PASSWORD=Seed1234!
VENDOR2_EMAIL=vendor2@aitt.test
VENDOR2_PASSWORD=Seed1234!
VENDOR3_EMAIL=vendor3@aitt.test
VENDOR3_PASSWORD=Seed1234!
VENDOR4_EMAIL=vendor4@aitt.test
VENDOR4_PASSWORD=Seed1234!

# Seeded entity IDs (written by seed.py after a successful run)
VENDOR1_ID=
VENDOR2_ID=
VENDOR3_ID=
VENDOR4_ID=
AUCTION_OPEN_ID=
AUCTION_CLOSED_ID=
AUCTION_PUBLISHED_ID=
