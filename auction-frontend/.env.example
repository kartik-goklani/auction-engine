# ─── Supabase ────────────────────────────────────────────────────────────────
# Find these in: Supabase dashboard → Project Settings → API

# Your Supabase project URL (format: https://<project-id>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://uxqicquaqrjbwmiigros.supabase.co

# Supabase anon/public key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─── Backend ─────────────────────────────────────────────────────────────────
# Base URL of the auction-backend NestJS server (no trailing slash)
# Local dev: http://localhost:3001
# Production: your Railway deployment URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket URL for Socket.IO — same host as the backend (NestJS serves both)
NEXT_PUBLIC_WS_URL=http://localhost:3001
